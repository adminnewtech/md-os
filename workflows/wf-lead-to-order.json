{
  "id": "wf-lead-to-order",
  "name": "Lead-to-Order",
  "trigger": {
    "type": "event",
    "source": "CRM",
    "event": "new_lead"
  },
  "nodes": [
    {
      "id": "1",
      "agent": "research",
      "action": "enrich_lead_data"
    },
    {
      "id": "2",
      "agent": "crm",
      "action": "score_qualify_lead"
    },
    {
      "id": "3",
      "condition": "score > 70",
      "true": "4",
      "false": "end"
    },
    {
      "id": "4",
      "agent": "sales",
      "action": "send_intro_schedule_demo"
    },
    {
      "id": "5",
      "condition": "interested",
      "true": "6",
      "false": "end"
    },
    {
      "id": "6",
      "agent": "sales",
      "action": "generate_proposal"
    },
    {
      "id": "7",
      "agent": "finance",
      "action": "review_pricing_apply_discounts"
    },
    {
      "id": "8",
      "condition": "deal_value > 50000",
      "true": "9",
      "false": "10"
    },
    {
      "id": "9",
      "agent": "ceo",
      "action": "approve"
    },
    {
      "id": "10",
      "agent": "workflow",
      "action": "create_order_notify_inventory_invoice"
    },
    {
      "id": "11",
      "agent": "support",
      "action": "onboarding_sequence"
    }
  ]
}